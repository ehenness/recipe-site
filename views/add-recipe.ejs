<!-- add-recipe.ejs -->
<body>
    <%- include('partials/navbar') %>
</body>
<h1>Add a New Recipe</h1>
<head> 
    <link rel="stylesheet" href="/styles.css">
</head>

<form action="/add-recipe" method="POST">
    <label for="name">Recipe Name:</label>
    <input type="text" id="name" name="name" required />

    <label for="protein_type">Protein Type:</label>
    <select id="protein_type" name="protein_type" required>
        <option value="Beef">Beef</option>
        <option value="Chicken">Chicken</option>
        <option value="Grains">Grains</option>
        <option value="Pork">Pork</option>
        <option value="Seafood">Seafood</option>
        <option value="Tofu">Tofu</option>
        <option value="Other">Other</option>
    </select>

    <label for="instructions">Instructions:</label>
    <textarea id="instructions" name="instructions" rows="8" required></textarea>

    <h3>Ingredients</h3>
    <% ingredients.forEach((ingredient, index) => { %>
        <div>
            <input type="checkbox" id="ingredient_<%= index %>" name="ingredient_ids[]" value="<%= ingredient.id %>" />
            <label for="ingredient_<%= index %>"><%= ingredient.name %></label>
            <input type="text" name="quantities[]" placeholder="Quantity" />
        </div>
    <% }); %>

    <button type="submit">Add Recipe</button>
</form>

<script>
    // client side
    document.getElementById('addRecipeForm').addEventListener('submit', function(e) {
        const checkboxes = document.querySelectorAll('input[name="ingredient_ids[]"]');
        const quantities = document.querySelectorAll('input[name="quantities[]"]');
        for (let i = 0; i < checkboxes.length; i++) {
            if (checkboxes[i].checked && quantities[i].value.trim() === '') {
                alert('Please enter a quantity for every selected ingredient.');
                e.preventDefault();
                return;
            }
        }
    });
</script>